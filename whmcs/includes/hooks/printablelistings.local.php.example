}

define('PRINTABLELISTINGS_API_URL', 'https://printablelistings.xyz/api/whmcs/webhook');
define('PRINTABLELISTINGS_WEBHOOK_SECRET', 'paste-same-value-as-WHMCS_WEBHOOK_SECRET-in-marketplace-env');
