# ValueScan standalone — https://valuescan.online
# Copy to /var/www/valuescan/.env on the VPS

APP_MODE=valuescan
NODE_ENV=production

# Dedicated port (do not use 4020 marketplace / 3002 Umami / 3000 Nexlify)
PORT=4030
VALUESCAN_API_PORT=4030
VALUESCAN_CLIENT_PORT=5190

VALUESCAN_DOMAIN=valuescan.online
VALUESCAN_URL=https://valuescan.online
CLIENT_URL=https://valuescan.online
VITE_VALUESCAN_URL=https://valuescan.online
VITE_APP_MODE=valuescan

# Separate SQLite database from marketplace
DATABASE_PATH=/var/www/valuescan/server/valuescan.db

JWT_SECRET=change-me-valuescan-production-secret

# Admin login (not shown in nav — use /admin directly)
VALUESCAN_ADMIN_EMAIL=admin@valuescan.online
VALUESCAN_ADMIN_PASSWORD=change-me-strong-admin-password

# Stripe subscriptions (optional — uses dynamic prices if IDs omitted)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VALUESCAN_PRO_PRICE_ID=
STRIPE_VALUESCAN_AGENCY_PRICE_ID=
# Webhook URL: https://valuescan.online/api/billing/webhook
# Optional SMTP for email alerts & support tickets
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@valuescan.online

# WHMCS + PayPal (same billing server as marketplace — billing.nexlify.live)
WHMCS_URL=
WHMCS_API_IDENTIFIER=
WHMCS_API_SECRET=
WHMCS_API_ACCESS_KEY=
WHMCS_WEBHOOK_SECRET=
WHMCS_PAYPAL_GATEWAY=paypal_ppcpv

# Same-server WHMCS bridge (recommended — bypasses API IP allowlist)
# Run: bash deploy/install-valuescan-whmcs-bridge.sh
WHMCS_BRIDGE_URL=http://127.0.0.1:9187/valuescan-api-bridge.php
VALUESCAN_BRIDGE_SECRET=

# Growth automation workers
GROWTH_WORKER_INTERVAL_MS=600000
GROWTH_PRO_INTERVAL_HOURS=24
GROWTH_AUTOPILOT_INTERVAL_HOURS=6
MONITOR_INTERVAL_MS=900000
