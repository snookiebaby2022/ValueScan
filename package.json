{
  "name": "marketplace-hub",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "workspaces": [
    "backend",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev:client\"",
    "dev:client": "vite --port 5180",
    "dev:valuescan": "concurrently \"npm run dev --workspace=backend\" \"npm run dev:valuescan:client\"",
    "dev:valuescan:client": "vite --port 5190",
    "build": "tsc -b && vite build",
    "build:valuescan": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:valuescan": "powershell -ExecutionPolicy Bypass -File deploy/push-valuescan.ps1"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.4.0",
    "ssh2": "^1.17.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
