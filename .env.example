# Printable Listings — ports avoid Nexlify (3000 panel / 3001 website)
PORT=4020
MARKETPLACE_API_PORT=4020
VITE_PORT=5180
MARKETPLACE_CLIENT_PORT=5180
CLIENT_URL=https://printablelistings.xyz
VITE_SITE_URL=https://printablelistings.xyz
SITE_URL=https://printablelistings.xyz

# Generate a strong random secret, e.g.:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production

# Stripe Connect + Checkout (optional — demo mode without keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# WHMCS billing — live PayPal at checkout (billing.nexlify.live)
# Create credentials: WHMCS Admin → Setup → Staff Management → Manage API Credentials
# Required API permissions: AddClient, GetClientsDetails, CreateInvoice, GetInvoice, GetPaymentMethods
WHMCS_URL=https://billing.nexlify.live
WHMCS_API_IDENTIFIER=
WHMCS_API_SECRET=
WHMCS_API_ACCESS_KEY=
WHMCS_WEBHOOK_SECRET=
# Auto-detected from WHMCS; override only if needed (yours is paypal_ppcpv)
WHMCS_PAYPAL_GATEWAY=paypal_ppcpv

# SEO / SEM analytics (optional)
VITE_GA_MEASUREMENT_ID=
VITE_GTM_ID=
# Umami — use stats subdomain, NOT the apex domain
VITE_UMAMI_URL=https://stats.printablelistings.xyz
VITE_UMAMI_WEBSITE_ID=

# ValueScan standalone site — https://valuescan.online (separate VPS deploy on port 4030)
# See deploy/VALUESCAN-DEPLOY.md and deploy/valuescan.env.example
VALUESCAN_DOMAIN=valuescan.online
VALUESCAN_URL=https://valuescan.online
VITE_VALUESCAN_URL=https://valuescan.online
